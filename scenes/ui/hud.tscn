[gd_scene load_steps=4 format=3 uid="uid://hud_v1_sanctuary"]

[ext_resource type="Script" path="res://scripts/ui/hud.gd" id="1_hud"]

[sub_resource type="Shader" id="Shader_desat"]
code = "shader_type canvas_item;
uniform float intensity : hint_range(0.0, 1.0) = 0.0;
void fragment() {
    vec4 col = texture(TEXTURE, UV);
    float gray = dot(col.rgb, vec3(0.299, 0.587, 0.114));
    COLOR = vec4(mix(col.rgb, vec3(gray), intensity), col.a);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_desat"]
