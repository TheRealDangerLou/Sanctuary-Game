# ──────────────────────────────────────────────────────────────
# Godot 4 — generated / cached data
# ──────────────────────────────────────────────────────────────

# Local editor state and import cache (regenerated on open)
.godot/

# Per-asset import metadata (regenerated by the editor)
*.import

# Compiled GDScript bytecode cache
*.gdc

# Translation binary cache
*.translation

# ──────────────────────────────────────────────────────────────
# Exports & builds
# ──────────────────────────────────────────────────────────────

# Export presets may contain signing keys / passwords
export_presets.cfg

# Build artefacts
export/
build/
dist/

# ──────────────────────────────────────────────────────────────
# Mono / C# (not used in this project, excluded for safety)
# ──────────────────────────────────────────────────────────────
.mono/
data_*/
mono_crash.*.json

# ──────────────────────────────────────────────────────────────
# OS-generated files
# ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ──────────────────────────────────────────────────────────────
# Editor / IDE
# ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ──────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────
*.swp
*~
*.orig
*.rej
*.bak
*.log
*.tmp
